rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // HELPER FUNCTIONS
    // =====================================================

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && userDoc().data.role == "admin"
        )
      );
    }

    function isDriver() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "driver";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // =====================================================
    // USERS
    // =====================================================

    match /users/{userId} {
      // User membaca datanya sendiri
      allow read: if isOwner(userId);

      // Driver & Admin membaca semua user
      allow read: if isDriver() || isAdmin();

      // Registrasi akun
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role in ["client", "driver"];

      // User update profil sendiri
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && !request.resource.data.values().hasAny([null]);

      // Admin bebas
      allow write: if isAdmin();
    }

    // =====================================================
    // PEMESANAN
    // =====================================================

    match /pemesanan/{docId} {

      // -------------------------
      // READ
      // -------------------------

      allow read: if signedIn() && (
        resource.data.uid == request.auth.uid ||
        isDriver() ||
        isAdmin()
      );

      // -------------------------
      // CREATE
      // Wajib ada deliveryAddress jika lokasi adalah Rumah atau Titik Temu
      // -------------------------

      allow create: if signedIn() && (
        (
          request.resource.data.uid == request.auth.uid
          && (
            !(request.resource.data.lokasiPenyerahan in ["Rumah", "Titik Temu"])
            || (
              "deliveryAddress" in request.resource.data
              && request.resource.data.deliveryAddress is string
              && request.resource.data.deliveryAddress != ""
            )
          )
        ) ||
        isAdmin()
      );

      // -------------------------
      // DELETE
      // -------------------------

      allow delete: if isAdmin();

      // -------------------------
      // ADMIN
      // -------------------------

      allow update: if isAdmin();

      // -------------------------
      // CLIENT
      // Upload bukti pembayaran
      // -------------------------

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "paymentMethod",
            "paymentProof",
            "paymentStatus",
            "waktuUpload",
            "dpAmount"
          ]);

      // -------------------------
      // DRIVER
      // -------------------------

      allow update: if isDriver()
        && (
          // Driver menerima order yang belum memiliki driver
          (
            (
              !("driverId" in resource.data) ||
              resource.data.driverId == null
            )
            && 
            request.resource.data.driverId == request.auth.uid
          )
          ||
          // Driver yang sudah menerima order
          (
            resource.data.driverId == request.auth.uid
            && request.resource.data.driverId == request.auth.uid
          )
        )
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "driverId",
            "status",
            "assignedAt",
            "updatedAt",
            "actualPaymentAmount",
            "paymentVerifiedAt"
          ]);
    }

    // =====================================================
    // MOBIL
    // =====================================================

    match /mobil/{mobilId} {
      // Semua user login dapat melihat mobil
      allow read: if signedIn();

      // Admin bebas
      allow create, delete: if isAdmin();

      allow update: if
        // Admin bebas
        isAdmin()
        ||
        // Client memperbarui status saat pemesanan
        (
          signedIn()
          && request.resource.data.status == "disewa"
          && request.resource.data.tersedia == false
        )
        ||
        // Driver hanya boleh update status mobil
        (
          isDriver()
          && request.resource.data.diff(resource.data).changedKeys()
              .hasOnly([
                "status",
                "tersedia",
                "updatedAt"
              ])
        );
    }

    // =====================================================
    // PAKET WISATA & TOUR PACKAGES
    // =====================================================

    match /paket_wisata/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /tour_packages/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // =====================================================
    // OPEN TRIP
    // =====================================================

    match /open_trips/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // =====================================================
    // COMPANY PROFILE
    // =====================================================

    match /company_profile/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // =====================================================
    // NOTIFICATIONS
    // =====================================================

    match /notifications/{notifId} {
      // User membaca notif miliknya
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      // Semua user login boleh membuat notifikasi
      allow create: if signedIn();

      // User mengubah notif miliknya
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid;

      // Admin bebas
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // DRIVER VERIFICATION
    // =====================================================

    match /vehicleVerifications/{docId} {
      // Driver membuat verifikasi miliknya sendiri
      allow create: if signedIn() && (
        request.resource.data.driverId == request.auth.uid ||
        isAdmin()
      );

      // Driver melihat verifikasi miliknya
      allow read: if signedIn() && (
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );

      // Driver mengubah verifikasi miliknya
      allow update: if signedIn()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == request.auth.uid;

      // Admin bebas
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // PAYMENT VERIFICATION
    // =====================================================

    match /paymentVerifications/{docId} {
      // Client / Driver membuat data
      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.driverId == request.auth.uid ||
          isAdmin()
        );

      // Melihat data
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.driverId == request.auth.uid ||
          isAdmin()
        );

      // Update
      allow update: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.driverId == request.auth.uid
        );

      // Admin bebas
      allow update, delete: if isAdmin();
    }

    // =====================================================
    // DRIVER ASSIGNMENTS
    // =====================================================

    match /driver_assignments/{docId} {
      // Create
      allow create: if signedIn()
        && (
          request.resource.data.driverId == request.auth.uid ||
          isAdmin()
        );

      // Read
      allow read: if signedIn()
        && (
          resource.data.driverId == request.auth.uid ||
          isAdmin()
        );

      // Update
      allow update: if signedIn()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == request.auth.uid;

      // Delete
      allow delete: if isAdmin();
    }
  }
}